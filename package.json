{
  "name": "micropython-esp32-s3",
  "version": "0.1.0",
  "author": "ArthurZheng",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/openblock-plugin/microPythonEsp32S3.git"
  },
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "npx openblock-registry-cli dev",
    "build": "npx openblock-registry-cli build",
    "build:obfuscate": "npx openblock-registry-cli build --obfuscate",
    "publish": "npx openblock-registry-cli publish",
    "publish:dry": "npx openblock-registry-cli publish --dry-run",
    "validate": "npx openblock-registry-cli validate",
    "i18n:update": "npx openblock-registry-cli i18n update",
    "lint": "eslint . --ext .js --fix"
  },
  "openblock": {
    "name": "Esp32-S3",
    "deviceId": "microPythonEsp32S3",
    "arch": [
      "microPython-esp32-s3"
    ],
    "manufactor": "espressif",
    "learnMore": "https://docs.espressif.com/projects/esp-dev-kits/en/latest/esp32s3/index.html",
    "type": "microPython",
    "iconURL": "./assets/microPythonEsp32S3.png",
    "description": {
      "formatMessage": {
        "id": "microPythonEsp32S3.description",
        "default": "Wi-Fi & Bluetooth control board powered by a dual-core Xtensa LX7 MCU."
      }
    },
    "bluetoothRequired": false,
    "serialportRequired": true,
    "defaultBaudRate": "115200",
    "internetConnectionRequired": false,
    "launchPeripheralConnectionFlow": true,
    "useAutoScan": false,
    "connectionIconURL": "./assets/microPythonEsp32S3-illustration.svg",
    "connectionSmallIconURL": "./assets/microPythonEsp32S3-small.svg",
    "main": "./src/microPythonEsp32S3.js",
    "generator": "./src/generator.js",
    "translations": "./src/translations.js",
    "programMode": [
      "upload"
    ],
    "tags": [
      "microPython"
    ],
    "helpLink": "https://wiki.openblock.cc/general-hardware-guidelines/boards/esp32-s3",
    "firmwares": [
      {
        "id": "standard",
        "name": "MicroPython Standard",
        "file": "./firmwares/ESP32_GENERIC_S3-20260406-v1.28.0.bin"
      }
    ],
    "examples": [
      {
        "id": "blink",
        "name": {
          "formatMessage": {
            "id": "microPythonEsp32S3.examples.blink.name",
            "default": "Blink"
          }
        },
        "description": {
          "formatMessage": {
            "id": "microPythonEsp32S3.examples.blink.description",
            "default": "Make the on-board LED blink."
          }
        },
        "file": "./examples/blink.ob"
      },
      {
        "id": "button",
        "name": {
          "formatMessage": {
            "id": "microPythonEsp32S3.examples.button.name",
            "default": "Button"
          }
        },
        "description": {
          "formatMessage": {
            "id": "microPythonEsp32S3.examples.button.description",
            "default": "Light up the LED while a push button is pressed."
          }
        },
        "file": "./examples/button.ob"
      },
      {
        "id": "fade",
        "name": {
          "formatMessage": {
            "id": "microPythonEsp32S3.examples.fade.name",
            "default": "Fade"
          }
        },
        "description": {
          "formatMessage": {
            "id": "microPythonEsp32S3.examples.fade.description",
            "default": "Smoothly fade an LED in and out using PWM."
          }
        },
        "file": "./examples/fade.ob"
      },
      {
        "id": "knob",
        "name": {
          "formatMessage": {
            "id": "microPythonEsp32S3.examples.knob.name",
            "default": "Knob"
          }
        },
        "description": {
          "formatMessage": {
            "id": "microPythonEsp32S3.examples.knob.description",
            "default": "Control LED brightness with a potentiometer."
          }
        },
        "file": "./examples/knob.ob"
      },
      {
        "id": "servoSweep",
        "name": {
          "formatMessage": {
            "id": "microPythonEsp32S3.examples.servoSweep.name",
            "default": "Servo Sweep"
          }
        },
        "description": {
          "formatMessage": {
            "id": "microPythonEsp32S3.examples.servoSweep.description",
            "default": "Sweep a servo back and forth between 0 and 180 degrees."
          }
        },
        "file": "./examples/servoSweep.ob"
      },
      {
        "id": "consolePrint",
        "name": {
          "formatMessage": {
            "id": "microPythonEsp32S3.examples.consolePrint.name",
            "default": "Console Print"
          }
        },
        "description": {
          "formatMessage": {
            "id": "microPythonEsp32S3.examples.consolePrint.description",
            "default": "Print messages to the MicroPython REPL console."
          }
        },
        "file": "./examples/consolePrint.ob"
      }
    ]
  },
  "devDependencies": {
    "babel-eslint": "^10.0.1",
    "eslint": "^5.3.0",
    "eslint-config-scratch": "^5.0.0",
    "husky": "^9.0.0"
  }
}
